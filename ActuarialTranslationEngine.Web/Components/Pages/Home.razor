@page "/"
@rendermode InteractiveServer
@using ActuarialTranslationEngine.Web.Services
@using ActuarialTranslationEngine.Core.Models
@using Microsoft.AspNetCore.SignalR.Client
@inject ApiTranslationClient TranslationClient
@inject IConfiguration Configuration
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<PageTitle>Governance Dashboard</PageTitle>

@if (!_showUploadScreen && _hasAuditHistory && !_isLoading && _response == null)
{
    <div class="glass-panel" style="max-width: 800px; margin: 40px auto; text-align: center;">
        <h1 class="gradient-text" style="margin-top: 0; margin-bottom: 24px;">Welcome to Actuarial Governance</h1>
        <p class="text-secondary" style="margin-bottom: 32px;">You have existing audits in your ledger. Would you like to upload a new model or review your history?</p>
        
        <div style="display: flex; gap: 24px; justify-content: center; margin-bottom: 40px;">
            <button class="btn-primary" @onclick="() => _showUploadScreen = true" style="padding: 16px 32px; font-size: 18px;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px; vertical-align: middle;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                Upload New Model
            </button>
            <a href="history" class="btn-secondary" style="padding: 16px 32px; font-size: 18px; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; color: var(--accent-purple); border: 1px solid rgba(139, 92, 246, 0.4); background: rgba(139, 92, 246, 0.1); border-radius: 6px;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                View Audit History
            </a>
        </div>

        @if (_recentAudits.Any())
        {
            <div style="margin-top: 40px; text-align: left;">
                <h3 style="color: var(--accent-cyan); border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 8px; margin-bottom: 16px;">Recent Audits</h3>
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="color: var(--text-secondary); border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 13px;">
                            <th style="padding: 8px 4px; text-align: left;">Time</th>
                            <th style="padding: 8px 4px; text-align: left;">Workbook</th>
                            <th style="padding: 8px 4px; text-align: left;">Sheet</th>
                            <th style="padding: 8px 4px; text-align: left;">Status</th>
                            <th style="padding: 8px 4px; text-align: right;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var audit in _recentAudits)
                        {
                            string statusColor = audit.Status == "Completed" ? "#34d399" : (audit.Status == "Failed" ? "#ef4444" : (audit.Status == "Canceled" ? "#f59e0b" : "#60a5fa"));
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 14px;">
                                <td style="padding: 12px 4px; color: var(--text-secondary);">@audit.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td style="padding: 12px 4px; font-weight: 500;">@audit.OriginalFileName</td>
                                <td style="padding: 12px 4px; font-style: italic; color: var(--text-secondary);">@audit.TargetSheet</td>
                                <td style="padding: 12px 4px; color: @statusColor;">@audit.Status</td>
                                <td style="padding: 12px 4px; text-align: right;">
                                    <a href="history/@audit.Id" class="btn-primary" style="padding: 4px 8px; font-size: 12px; text-decoration: none;">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}
else if (_activeSession != null)
{
    <div class="glass-panel" style="max-width: 800px; margin: 40px auto;">
        <h1 class="gradient-text" style="margin-top: 0;">Interactive Translation Wizard</h1>
        <p class="text-secondary" style="margin-bottom: 24px;">Session ID: @_activeSession.SessionId</p>
        
        <div style="margin-top: 16px;">
            @foreach (var job in _activeSession.Jobs)
            {
                <div style="padding: 12px; margin-bottom: 8px; border: 1px solid rgba(139, 92, 246, 0.4); border-radius: 6px; display: flex; justify-content: space-between; align-items: center; background: @(job.Status == "Completed" ? "rgba(16, 185, 129, 0.1)" : job.Status == "Running" ? "rgba(59, 130, 246, 0.1)" : "rgba(0,0,0,0.3)")">
                    <span style="color: #e2e8f0; font-weight: bold;">Sheet: @job.TargetSheet</span>
                    <span style="color: var(--text-secondary);">Status: @job.Status</span>
                    @if (job.Status == "Pending" && !_isLoading)
                    {
                        <button class="btn-primary" @onclick="() => ExecuteJobAsync(job.Id)">Translate</button>
                    }
                    else if (job.Status == "Running")
                    {
                        <button class="btn-primary" style="background: rgba(220, 38, 38, 0.2); border-color: rgba(220, 38, 38, 0.4); color: #f87171;" @onclick="() => CancelJobAsync(job.Id)">Cancel Translation</button>
                    }
                    else if (job.Status == "Completed")
                    {
                        <button class="btn-secondary" @onclick="() => LoadResponseAsync(job.Id)">View Ledger</button>
                    }
                </div>
            }
        </div>
        
        @if (!_activeSession.Jobs.Any(j => j.Status == "Pending" || j.Status == "Running"))
        {
             <div style="margin-top: 24px;">
                 <button class="btn-secondary" @onclick="FinishSessionAsync">Finish Session</button>
             </div>
        }
        
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div style="margin-top: 24px; padding: 16px; background: rgba(220, 38, 38, 0.1); border-left: 4px solid #dc2626; border-radius: 4px;">
                <strong style="color: #fca5a5;">Error:</strong> <span style="color: #f8fafc;">@_errorMessage</span>
            </div>
        }
    </div>
}
else
{
    <div class="glass-panel" style="max-width: 800px; margin: 40px auto;">
    <h1 class="gradient-text" style="margin-top: 0;">Upload Model for Translation</h1>
    <p class="text-secondary" style="margin-bottom: 24px;">Select an Excel workbook (.xlsx or .xlsm) to initiate the domain interrogation and C# dynamic compilation pipeline.</p>

    <label class="upload-zone" style="display: block;">
        <InputFile OnChange="HandleFileSelected" accept=".xlsx,.xlsm" style="display: none;" />
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--accent-cyan)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" y1="3" x2="12" y2="15"></line>
        </svg>
        <h3 style="margin-top: 16px; margin-bottom: 8px;">@_fileName</h3>
        @if (_selectedFile == null)
        {
            <p style="color: var(--text-secondary); margin: 0;">Click to browse or drag and drop</p>
        }
    </label>

    @if (_availableSheets.Any() || _isInspecting)
    {
        <div style="margin-top: 16px;">
            <label style="display: block; color: var(--text-secondary); margin-bottom: 8px;">Target Sheet:</label>
            <select @bind="_targetSheet" disabled="@_isInspecting" style="width: 100%; padding: 12px; border-radius: 6px; background: rgba(0,0,0,0.3); color: #e2e8f0; border: 1px solid rgba(139, 92, 246, 0.4); outline: none;">
                @if (_isInspecting)
                {
                    <option value="">Inspecting file...</option>
                }
                else
                {
                    <option value="">-- Select a Sheet --</option>
                    @foreach (var sheet in _availableSheets)
                    {
                        <option value="@sheet">@sheet</option>
                    }
                }
            </select>
        </div>
    }

    <div style="margin-top: 24px; display: flex; justify-content: space-between; align-items: center;">
        <div style="display: flex; gap: 12px;">
            @if (_hasAuditHistory)
            {
                <button class="btn-secondary" @onclick="() => _showUploadScreen = false" style="padding: 10px 16px; border-radius: 6px;">
                    &larr; Back to Dashboard
                </button>
            }
            <a href="history" class="btn-secondary" style="padding: 10px 16px; border-radius: 6px; text-decoration: none; color: var(--accent-purple); border: 1px solid rgba(139, 92, 246, 0.4); background: rgba(139, 92, 246, 0.1); display: inline-flex; align-items: center;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                View Audit History Ledger
            </a>
        </div>
        <button class="btn-primary" @onclick="ConfigureSessionAsync" disabled="@(_selectedFile == null || _isLoading || _isInspecting || string.IsNullOrEmpty(_targetSheet))">
            @if (_isLoading)
            {
                <span>Configuring Session...</span>
            }
            else
            {
                <span>Configure Translation Session</span>
            }
        </button>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div style="margin-top: 24px; padding: 16px; background: rgba(220, 38, 38, 0.1); border-left: 4px solid #dc2626; border-radius: 4px;">
            <strong style="color: #fca5a5;">Error:</strong> <span style="color: #f8fafc;">@_errorMessage</span>
        </div>
    }
    </div>
}

@if (_isLoading)
{
    <div style="margin-top: 32px; background: rgba(0,0,0,0.2); padding: 24px; border-radius: 12px; border: 1px solid rgba(6, 182, 212, 0.2); max-width: 800px; margin-left: auto; margin-right: auto;">
        <h4 style="color: var(--accent-cyan); margin-top: 0; margin-bottom: 16px;">Translation Progress</h4>
        
        <div style="height: 8px; background: rgba(255,255,255,0.1); border-radius: 4px; overflow: hidden; margin-bottom: 16px;">
            <div style="height: 100%; width: @(_percentComplete)%; background: var(--accent-cyan); transition: width 0.3s ease;"></div>
        </div>
        
        <div style="display: flex; justify-content: space-between; color: var(--text-secondary); font-size: 14px; margin-bottom: 16px;">
            <span>@_currentStatusMessage</span>
            <span>@Math.Round(_percentComplete, 1)%</span>
        </div>

        <div style="background: rgba(0,0,0,0.3); padding: 12px; border-radius: 8px; max-height: 150px; overflow-y: auto; font-family: monospace; font-size: 12px; color: #a1a1aa;">
            @foreach (var log in _progressLogs)
            {
                <div style="margin-bottom: 4px;">> @log</div>
            }
        </div>
    </div>
}

@if (_response != null && _response.Evaluations.Any())
{
    <div class="glass-panel" style="max-width: 1400px; margin: 0 auto 24px auto; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3);">
        <h3 style="color: #34d399; margin-top: 0; margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            Committed to Audit Ledger
        </h3>
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; color: #e2e8f0; font-size: 14px;">
            <div><strong>Transaction ID:</strong><br/> <span style="font-family: monospace;">@_response.TranslationId</span></div>
            <div><strong>Timestamp:</strong><br/> @_response.Timestamp.ToLocalTime().ToString("g")</div>
            <div><strong>LLM Model:</strong><br/> @_response.ModelUsed</div>
            <div><strong>Database:</strong><br/> audit.db</div>
        </div>
    </div>

    <div class="glass-panel" style="max-width: 1400px; margin: 0 auto 40px auto; background: rgba(0,0,0,0.2);">
        <h3 style="margin-top: 0; margin-bottom: 16px; font-size: 20px;">Architecture Overview</h3>
        <div style="display: flex; gap: 24px; flex-wrap: wrap;">
            <div style="flex: 1; min-width: 300px;">
                <h4 style="color: var(--accent-purple); margin-top: 0; margin-bottom: 8px;">Semantic Specification</h4>
                <p style="font-size: 13px; color: var(--text-secondary); margin: 0;">The mathematical formulation extracted directly from Excel formulas. This provides a human-readable format allowing actuaries to verify the core logic without reading raw software code.</p>
            </div>
            <div style="flex: 1; min-width: 300px;">
                <h4 style="color: var(--accent-cyan); margin-top: 0; margin-bottom: 8px;">Compiled C# Runtime</h4>
                <p style="font-size: 13px; color: var(--text-secondary); margin: 0;">The executable software source code automatically generated from the Semantic Specification. This is the exact code that will be executed, ensuring 1:1 parity with the verified actuary logic.</p>
            </div>
        </div>
    </div>

    <div class="glass-panel" style="max-width: 1400px; margin: 0 auto 24px auto; background: rgba(0,0,0,0.2); border: 1px solid rgba(139, 92, 246, 0.2);">
        <h3 style="color: var(--accent-purple); margin-top: 0; margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
            Semantic Specification HEADER
        </h3>
        <div style="max-height: 400px; overflow-y: auto; overflow-x: auto;">
            <pre style="white-space: pre-wrap; font-family: 'Inter', sans-serif; font-size: 14px; color: #e2e8f0; line-height: 1.6; margin: 0;">@_response.Evaluations.First().FinalAuditableMarkdown</pre>
        </div>
    </div>

    int partitionIndex = 1;
    foreach (var eval in _response.Evaluations)
    {
        int currentIndex = partitionIndex++;
        <div class="glass-panel result-card" style="max-width: 1400px; margin: 0 auto 40px auto; background: rgba(0,0,0,0.2);">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-glass); padding-bottom: 16px; margin-bottom: 24px;">
                <h3 style="margin: 0; font-size: 24px; display: flex; align-items: center; gap: 12px;">
                    <span>Compiled: <span style="color: var(--accent-cyan);">@(string.IsNullOrEmpty(eval.SourceName) ? $"Partition {currentIndex}" : eval.SourceName)</span></span>
                    @if (eval.IsCertified)
                    {
                        <span style="font-size: 14px; padding: 4px 12px; border-radius: 999px; background: rgba(16, 185, 129, 0.2); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.4); display: inline-flex; align-items: center; gap: 6px;">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                            Certified: Zero Variance
                        </span>
                    }
                    else
                    {
                        <span style="font-size: 14px; padding: 4px 12px; border-radius: 999px; background: rgba(220, 38, 38, 0.2); color: #f87171; border: 1px solid rgba(220, 38, 38, 0.4); display: inline-flex; align-items: center; gap: 6px;">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                            Reconciliation Failure
                        </span>
                    }
                </h3>
            </div>

            @if (!eval.IsCertified)
            {
                <div style="background: rgba(220, 38, 38, 0.1); border-left: 4px solid #dc2626; padding: 16px; margin-bottom: 24px; border-radius: 4px;">
                    <h4 style="margin: 0 0 8px 0; color: #fca5a5;">Validation Error</h4>
                    <p style="margin: 0; color: #f8fafc;">@eval.ErrorMessage</p>
                    @if (eval.VarianceDelta.HasValue)
                    {
                        <p style="margin: 8px 0 0 0; color: #fca5a5; font-family: monospace;"><strong>Variance Delta:</strong> @eval.VarianceDelta.Value</p>
                    }
                </div>
            }

            @if (eval.DisruptiveNodes != null && eval.DisruptiveNodes.Any())
            {
                <div style="background: rgba(245, 158, 11, 0.1); border-left: 4px solid #f59e0b; padding: 16px; margin-bottom: 24px; border-radius: 4px;">
                    <h4 style="margin: 0 0 8px 0; color: #fbbf24; display: flex; align-items: center; gap: 8px;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                        Spreadsheet Anomalies Detected
                    </h4>
                    <ul style="margin: 0; padding-left: 20px; color: #f8fafc; font-size: 14px;">
                        @foreach (var node in eval.DisruptiveNodes)
                        {
                            <li style="margin-bottom: 4px;">
                                <strong>@node.Coordinate</strong>: <span style="font-family: monospace; color: #fbbf24;">@node.RawFormula</span> 
                                (@(node.ExceptionFlag.ToString()))
                            </li>
                        }
                    </ul>
                </div>
            }

            <div style="display: flex; flex-direction: column; gap: 16px;">
                <div style="background: rgba(0,0,0,0.3); padding: 20px; border-radius: 12px; border: 1px solid rgba(6, 182, 212, 0.2);">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px;">
                        <h4 style="color: var(--accent-cyan); margin: 0; display: flex; align-items: center; gap: 8px;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
                            C# Runtime @(string.IsNullOrEmpty(eval.SourceName) ? $"(Partition {currentIndex})" : "")
                        </h4>
                        <button class="btn-primary" style="padding: 6px 12px; font-size: 12px; background: rgba(6, 182, 212, 0.2); border-color: rgba(6, 182, 212, 0.4); color: var(--accent-cyan);" @onclick="() => DownloadCodeAsync(eval.GeneratedCSharpMirrorCode, currentIndex)">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px; display: inline-block; vertical-align: middle;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                            Download .cs
                        </button>
                    </div>
                    <div class="code-block" style="max-height: 600px; overflow-y: auto; overflow-x: auto; width: 100%;">
                        <pre style="margin: 0;"><code>@eval.GeneratedCSharpMirrorCode</code></pre>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    private IBrowserFile? _selectedFile;
    private string _fileName = "Select Workbook";
    private string _targetSheet = "";
    private List<string> _availableSheets = new();
    private Guid _tempSessionId;
    private bool _isInspecting = false;
    private bool _isLoading = false;
    private string? _errorMessage;
    private ApiTranslationResponse? _response;
    private SessionCreateResponse? _activeSession;

    private HubConnection? _hubConnection;
    private List<string> _progressLogs = new();
    private double _percentComplete = 0;
    private string _currentStatusMessage = "Initializing...";

    private bool _hasAuditHistory = false;
    private bool _showUploadScreen = false;
    private List<HistorySummary> _recentAudits = new();

    protected override async Task OnInitializedAsync()
    {
        var apiUrl = Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5158";

        if (Configuration["Testing:DisableSignalR"] != "true")
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl($"{apiUrl}/progressHub")
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<TranslationProgressEvent>("ProgressUpdated", (progressEvent) =>
            {
                _percentComplete = progressEvent.PercentComplete;
                _currentStatusMessage = progressEvent.Message;
                _progressLogs.Add(progressEvent.Message);
                InvokeAsync(StateHasChanged);
            });

            _hubConnection.On<TranslationCompletedEvent>("TranslationCompleted", async (completedEvent) =>
            {
                _isLoading = false;
                if (completedEvent.Success)
                {
                    _percentComplete = 100;
                    _currentStatusMessage = completedEvent.Message;
                    _progressLogs.Add(completedEvent.Message);
                    if (_activeSession != null)
                    {
                        var job = _activeSession.Jobs.FirstOrDefault(j => j.Id == completedEvent.TranslationId);
                        if (job != null) job.Status = "Completed";
                    }
                }
                else
                {
                    _errorMessage = completedEvent.ErrorMessage ?? "Translation failed.";
                    _currentStatusMessage = "Failed.";
                }

                await InvokeAsync(StateHasChanged);
            });

            try
            {
                await _hubConnection.StartAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"SignalR connection failed: {ex.Message}");
            }
        }
        try
        {
            var history = await TranslationClient.GetHistoryAsync(0, 5);
            if (history != null && history.Any())
            {
                _hasAuditHistory = true;
                _recentAudits = history;
            }
            else
            {
                _showUploadScreen = true;
            }
        }
        catch
        {
            _showUploadScreen = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var sessionIdStr = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "activeSessionId");
                if (!string.IsNullOrEmpty(sessionIdStr) && Guid.TryParse(sessionIdStr, out var sessionId))
                {
                    var session = await TranslationClient.GetSessionJobsAsync(sessionId);
                    if (session != null && session.Jobs.Any())
                    {
                        _activeSession = session;
                        _showUploadScreen = false;
                        await InvokeAsync(StateHasChanged);
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error restoring session: {ex.Message}");
            }
        }
    }

    private async Task FinishSessionAsync()
    {
        if (_activeSession != null)
        {
            try
            {
                await TranslationClient.FinishSessionAsync(_activeSession.SessionId);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Failed to clean up session: {ex.Message}");
            }
        }

        try
        {
            await JSRuntime.InvokeVoidAsync("sessionStorage.removeItem", "activeSessionId");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to clear session storage: {ex.Message}");
        }

        _activeSession = null;
        _errorMessage = null;
        _response = null;
        
        try
        {
            var history = await TranslationClient.GetHistoryAsync(0, 5);
            if (history != null && history.Any())
            {
                _hasAuditHistory = true;
                _recentAudits = history;
                _showUploadScreen = false; // Go back to welcome page showing recent history
            }
            else
            {
                _showUploadScreen = true;
            }
        }
        catch
        {
            _showUploadScreen = true;
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
        _fileName = _selectedFile.Name;
        _errorMessage = null;
        _response = null;
        _targetSheet = "";
        _availableSheets.Clear();
        _isInspecting = true;
        
        try
        {
            var response = await TranslationClient.UploadFileAsync(_selectedFile);
            _tempSessionId = response.SessionId;
            _availableSheets = response.AvailableSheets;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to inspect file: {ex.Message}";
        }
        finally
        {
            _isInspecting = false;
        }
    }

    private async Task ConfigureSessionAsync()
    {
        if (_tempSessionId == Guid.Empty) return;
        _isLoading = true;
        _errorMessage = null;
        try
        {
            _activeSession = await TranslationClient.ConfigureSessionAsync(_tempSessionId, _targetSheet);
            if (_activeSession != null)
            {
                try
                {
                    await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "activeSessionId", _activeSession.SessionId.ToString());
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Failed to save session to storage: {ex.Message}");
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ExecuteJobAsync(Guid jobId)
    {
        _isLoading = true;
        _percentComplete = 0;
        _errorMessage = null;
        _progressLogs.Clear();
        _currentStatusMessage = "Initializing extraction...";
        _response = null;
        try
        {
            var job = _activeSession?.Jobs.FirstOrDefault(j => j.Id == jobId);
            if (job != null) job.Status = "Running";

            if (_hubConnection != null && _hubConnection.State == HubConnectionState.Connected)
                await _hubConnection.InvokeAsync("JoinJobGroup", jobId.ToString());

            await TranslationClient.ExecuteSessionJobAsync(_activeSession!.SessionId, jobId, null);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _isLoading = false;
        }
    }

    private async Task LoadResponseAsync(Guid jobId)
    {
        _response = await TranslationClient.GetHistoricalTranslationAsync(jobId);
    }

    private async Task CancelJobAsync(Guid jobId)
    {
        try
        {
            await TranslationClient.CancelJobAsync(jobId);
            var job = _activeSession?.Jobs.FirstOrDefault(j => j.Id == jobId);
            if (job != null) job.Status = "Canceled";
            _isLoading = false;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task DownloadCodeAsync(string code, int index)
    {
        string filename = $"{_response?.WorkbookName}_{_response?.WorksheetName}_partition_{index}_translated.cs".Replace(" ", "_");
        await JSRuntime.InvokeVoidAsync("downloadFileFromText", filename, code);
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }
}
